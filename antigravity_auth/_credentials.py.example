# OAuth client credentials for the Antigravity plugin.
#
# Copy this file to _credentials.py and fill in your values:
#   cp antigravity_auth/_credentials.py.example antigravity_auth/_credentials.py
#
# Alternatively, set the environment variables:
#   export ANTIGRAVITY_CLIENT_ID="your-client-id.apps.googleusercontent.com"
#   export ANTIGRAVITY_CLIENT_SECRET="GOCSPX-your-secret"
#
# The plugin will read _credentials.py first, then fall back to the
# environment variables. If neither is set, the plugin degrades gracefully —
# Hermes will use its built-in OAuth client instead.
#
# To get credentials:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a "Desktop application" OAuth 2.0 client ID
#   3. Add http://127.0.0.1:8085/oauth2callback as an authorized redirect URI
#   4. Copy the client ID and secret below

ANTIGRAVITY_CLIENT_ID = "your-client-id.apps.googleusercontent.com"
ANTIGRAVITY_CLIENT_SECRET = "GOCSPX-your-secret-here"
